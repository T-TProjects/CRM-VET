# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Gmail OAuth (email notifications + reply tracking) ───────
# Create an OAuth client at https://console.cloud.google.com (Web application).
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/gmail/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Cron ─────────────────────────────────────────────────────
# Shared secret so scheduled jobs (gmail sync, no-reply chase) can call the API.
CRON_SECRET=generate-a-long-random-string

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
